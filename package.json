{
  "name": "yapi-vendor",
  "version": "1.11.0",
  "description": "YAPI",
  "license": "Apache-2.0",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git@github.com:hackmagic/yapi-plus.git"
  },
  "main": "server/app.js",
  "scripts": {
    "dev-copy-icon": "node -e \"require('fs-extra').copySync('static/iconfont', './iconfont', {overwrite: true});\"",
    "dev-server": "nodemon server/app.js dev -L",
    "install-server": "node server/install.js",
    "dev-client": "npm run dev-copy-icon && vp dev",
    "dev": "concurrently -n \"Server,Client\" -c \"blue,green\" \"npm run dev-server\" \"npm run dev-client\"",
    "dev:fast": "concurrently -n \"Server,Client\" -c \"blue,green\" \"npm run dev-server\" \"vp dev\"",
    "build": "vp build",
    "build-client": "vp build",
    "check": "vp check",
    "fmt": "vp fmt",
    "lint": "vp lint",
    "lint:client": "eslint \"client/**/*.{js,vue}\"",
    "start": "node server/app.js",
    "start:all": "concurrently -n \"Server,Client\" -c \"blue,green\" \"npm start\" \"vp preview\"",
    "test": "ava",
    "test:e2e": "playwright test --config=test/e2e/config.js",
    "test:e2e:ui": "playwright test --config=test/e2e/config.js --ui",
    "test:e2e:headed": "playwright test --config=test/e2e/config.js --headed",
    "test:e2e:debug": "playwright test --config=test/e2e/config.js --debug",
    "test:e2e:report": "playwright show-report test-results/html-report",
    "test:ui": "playwright test test/e2e/tests/ui-tests.test.js --config=test/e2e/config.js",
    "test:functional": "playwright test test/e2e/tests/functional-tests.test.js --config=test/e2e/config.js",
    "test:ai": "playwright test test/e2e/tests/ai-agent-tests.test.js --config=test/e2e/config.js",
    "test:perf": "playwright test test/e2e/tests/performance-tests.test.js --config=test/e2e/config.js",
    "test:all": "playwright test --config=test/e2e/config.js",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "package": "node scripts/package.js",
    "release": "node -e \"var v='v'+require('./package.json').version; require('child_process').execSync('git tag '+v+' && git push origin '+v,{stdio:'inherit'})\"",
    "npm-publish": "node ./npm-publish.js",
    "docs": "ydoc build"
  },
  "dependencies": {
    "@vicons/ionicons5": "^0.13.0",
    "ace-builds": "^1.43.6",
    "ajv": "^5.5.1",
    "ajv-i18n": "^2.2.0",
    "axios": "0.18.1",
    "compare-versions": "^3.4.0",
    "copy-to-clipboard": "3.0.8",
    "cpu-load": "^1.0.0",
    "crypto-js": "^3.1.9-1",
    "easy-json-schema": "0.0.2-beta",
    "fs-extra": "^3.0.1",
    "generate-schema": "^2.6.0",
    "js-base64": "^2.3.2",
    "json-schema-faker": "0.5.0-rc16",
    "json5": "0.5.1",
    "jsondiffpatch": "0.3.11",
    "jsonwebtoken": "7.4.1",
    "jsrsasign": "^8.0.12",
    "koa": "2.0.0",
    "koa-body": "^2.5.0",
    "koa-router": "^7.0.1",
    "koa-static": "3.0.0",
    "koa-websocket": "4.0.0",
    "ldapjs": "^1.0.1",
    "markdown-it": "8.4.0",
    "markdown-it-anchor": "4.0.0",
    "markdown-it-table-of-contents": "0.3.2",
    "marked": "^18.0.3",
    "md5": "2.2.1",
    "mockjs": "1.0.1-beta3",
    "mongoose": "5.7.5",
    "naive-ui": "^2.34.4",
    "node-schedule": "^1.3.2",
    "nodemailer": "4.0.1",
    "os": "0.1.1",
    "pinia": "^3.0.4",
    "qs": "^6.7.0",
    "safeify": "^5.0.5",
    "sha.js": "2.4.9",
    "sha1": "1.1.1",
    "swagger-client": "^3.5.1",
    "underscore": "1.8.3",
    "url": "0.11.0",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "vuedraggable": "^4.1.0",
    "yapi-plugin-qsso": "^1.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitejs/plugin-vue-jsx": "^5.0.0",
    "adm-zip": "^0.5.10",
    "ava": "^0.22.0",
    "babel-register": "^6.26.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.34.0",
    "eslint-plugin-vue": "^10.9.0",
    "less": "^4.6.4",
    "nodemon": "^1.11.0",
    "playwright": "^1.59.1",
    "rewire": "^9.0.1",
    "sass": "^1.58.0",
    "validate-commit-msg": "^2.12.2",
    "vite": "^8.0.10",
    "vite-plus": "^0.1.19",
    "ydoc-plugin-img-view": "^1.0.1"
  },
  "config": {
    "ghooks": {
      "commit-msg": "validate-commit-msg"
    },
    "validate-commit-msg": {
      "types": [
        "feat",
        "fix",
        "docs",
        "test",
        "chore",
        "refactor",
        "opti"
      ],
      "warnOnFail": false,
      "maxSubjectLength": 100,
      "subjectPattern": ".+",
      "subjectPatternErrorMsg": "请输入message信息!",
      "helpMessage": "Commit message 格式错误， http://www.ruanyifeng.com/blog/2016/01/commit_message_change_log.html"
    }
  },
  "ava": {
    "files": [
      "test/**/*.test.js"
    ],
    "require": [
      "./test/babel-register.js"
    ]
  },
  "engines": {
    "node": ">= 18.0.0",
    "npm": ">= 9.0.0"
  },
  "scripts-info": {
    "start": "运行生产环境服务器（仅后端）",
    "start:all": "运行生产环境（前端+后端）",
    "install-server": "初始化数据库数据，用于安装",
    "dev": "运行开发服务器（前端+后端，推荐）",
    "dev:fast": "快速启动开发服务器（跳过图标复制）",
    "dev-server": "运行后端开发服务器",
    "dev-client": "运行前端开发服务器",
    "test": "执行测试"
  }
}
